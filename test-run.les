# title:   A test script for lesim-mode 
# author:  Stefano Ghirlanda
# date:    2023-05-24 
# summary: Run it with C-c C-c.

n_subjects        = 10
mechanism         = a
behaviors         = response, no_response 
stimulus_elements = background, stimulus, reward 
start_v           = 0.1
start_w           = 0.1
alpha_v           = 0.1
alpha_w           = 0.1
u                 = reward:10, default:0
beta              = 1

@phase training stop: START_TRIAL=10
START0                  | x=0, START_TRIAL
START_TRIAL stimulus[x] | x=x+0.01, response: REWARD | NO_REWARD
REWARD      reward      | @omit_learn, START_TRIAL
NO_REWARD   background  | @omit_learn, START_TRIAL

xscale: START_TRIAL
subject: average

@run training

@figure v(stimulus->response)
@panel 111 {'xlabel':'exposures to stimulus', 'ylabel':'v-value'}
@vplot stimulus->response
@legend
