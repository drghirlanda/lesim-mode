n_subjects        = 1 # end of line comment 
mechanism         = sr
behaviors         = response, no_response 
stimulus_elements = background, stimulus, reward 
start_v           = 0.1
start_w           = 0.1
alpha_v           = 0.1
u                 = reward:10, default:0
beta              = 1x # invalid value

###
Highlighted typos in @phase blocks:
###
@phase training1 stop: stimulus==500
START_TRIAL  stimulus,background | rand():START_TRIAL, count_reset(REWARD), 1x=2, response: REWARD(.5) | NO_REWARD
REWARD       rewar               | 1 or response: START_TRIAL
NO_REWARD    background          | START_TRIA

# correct phase block:
@phase training2 stop: stimulus==500
START_TRIAL  stimulus,background | response: REWARD(.5) | NO_REWARD
REWARD       reward              | START_TRIAL
NO_REWARD    background          | START_TRIAL
                 
# these are wrong:
@run xtraining
@run training1, xtraining2
@run my_run training1, xtraining2
@run my_run xtraining
             
# these are correct:
@run training1
@run my_run training1
@run training1, training2
@run my_run training1, training2

@figure v(stimulus->response)
@subplot 111 {'xlabel':'exposures to stimulus', 'ylabel':'v-value'}
@vplot stimulus->response

